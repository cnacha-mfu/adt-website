# Copy to .env for docker compose, or to .env.local for local dev

# Password used by both the postgres container and the app's DATABASE_URL
POSTGRES_PASSWORD=changeme

# For local dev (npm run dev) point directly at your local postgres instance
# DATABASE_URL=postgresql://adt:changeme@localhost:5432/adt

# Resend (https://resend.com) — used by the Dean Hotline contact form
# Sign up at resend.com, create an API key, and set it here.
# RESEND_FROM must be a verified domain sender. During testing use onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=ADT Hotline <noreply@adt.mfu.ac.th>
